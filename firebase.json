{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "*.bat", "*.sh", "DEPLOY_README.txt"],
    "rewrites": [{"source": "**", "destination": "/index.html"}],
    "headers": [
      {
        "source": "**",
        "headers": [
          {"key": "Cache-Control", "value": "no-cache"},
          {"key": "Permissions-Policy", "value": "camera=*"}
        ]
      }
    ]
  }
}
